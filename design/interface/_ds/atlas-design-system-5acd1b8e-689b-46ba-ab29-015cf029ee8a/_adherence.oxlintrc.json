{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/dashboard/**",
              "ui_kits/editor/**",
              "ui_kits/game-session/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cinzel|Public Sans|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Cinzel, Public Sans, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|status|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, status, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:neutral|success|warning|danger|info|brass)$/]",
        "message": "<Badge> status must be one of 'neutral' | 'success' | 'warning' | 'danger' | 'info' | 'brass'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|surface|disabled|leftIcon|rightIcon|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, surface, disabled, leftIcon, rightIcon, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:paper|field)$/]",
        "message": "<Button> surface must be one of 'paper' | 'field'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|surface|padding|elevated|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, surface, padding, elevated, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:paper|field)$/]",
        "message": "<Card> surface must be one of 'paper' | 'field'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|onChange|surface|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, checked, onChange, surface, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:paper|field)$/]",
        "message": "<Checkbox> surface must be one of 'paper' | 'field'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|children|footer|width|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, onClose, title, children, footer, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|surface|active|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, size, surface, active, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:paper|field)$/]",
        "message": "<IconButton> surface must be one of 'paper' | 'field'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|error|hint|surface|icon|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, error, hint, surface, icon, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:paper|field)$/]",
        "message": "<Input> surface must be one of 'paper' | 'field'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Radio'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|onChange|name|surface|style|key|ref|className|style|children)$/]",
        "message": "<Radio> doesn't accept that prop. Declared props: label, checked, onChange, name, surface, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Radio'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:paper|field)$/]",
        "message": "<Radio> surface must be one of 'paper' | 'field'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|surface|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, surface, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:paper|field)$/]",
        "message": "<Switch> surface must be one of 'paper' | 'field'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|onRemove|surface|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, onRemove, surface, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:paper|field)$/]",
        "message": "<Tag> surface must be one of 'paper' | 'field'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|status|onDismiss|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: title, description, status, onDismiss."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:neutral|success|warning|danger|info)$/]",
        "message": "<Toast> status must be one of 'neutral' | 'success' | 'warning' | 'danger' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|label|side|key|ref|className|style|children)$/]",
        "message": "<Tooltip> doesn't accept that prop. Declared props: children, label, side."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute[name.name='side'] > Literal[value!=/^(?:top|bottom|left|right)$/]",
        "message": "<Tooltip> side must be one of 'top' | 'bottom' | 'left' | 'right'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
